    "@studyhub/ui": "workspace:*",
    "@tailwindcss/postcss": "^4.1.11",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "mermaid": "^11.16.0",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@types/node": "^24.0.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
