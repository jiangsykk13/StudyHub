{
  "name": "@studyhub/web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "node ../../scripts/ensure-next-swc.mjs && next dev --port 3000",
    "build": "node ../../scripts/ensure-next-swc.mjs && next build",
    "start": "next start --port 3000",
