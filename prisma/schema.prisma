generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SYSTEM_ADMIN
  MEMBER
}

enum CourseMemberRole {
  COURSE_ADMIN
  MEMBER
  READ_ONLY
}

enum InvitationScope {
  ALL_SITE
  COURSE
}

enum ResourceVisibility {
  COURSE_MEMBERS
  ALL_MEMBERS
  PRIVATE
}

enum NoteVisibility {
  PRIVATE
  COURSE_MEMBERS
  ALL_MEMBERS
}

enum FavoriteTargetType {
  RESOURCE
  NOTE
}

enum AuditAction {
  USER_DISABLED
  USER_ENABLED
  USER_SESSIONS_REVOKED
  USER_ROLE_CHANGED
  COURSE_CREATED
  COURSE_UPDATED
  COURSE_ARCHIVED
  COURSE_MEMBER_CHANGED
  INVITATION_CREATED
  INVITATION_REVOKED
  RESOURCE_CREATED
  RESOURCE_VERSION_CREATED
  RESOURCE_DELETED
  RESOURCE_RESTORED
  NOTE_CREATED
  NOTE_UPDATED
  NOTE_DELETED
  NOTE_REVISION_RESTORED
}

model User {
  id             String         @id @default(uuid()) @db.Uuid
  email          String         @unique
  displayName    String
  passwordHash   String
  role           UserRole       @default(MEMBER)
  disabledAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  sessions       Session[]
  memberships    CourseMember[]
  invitations    Invitation[]   @relation("InvitationCreator")
  resources      Resource[]     @relation("ResourceUploader")
  resourceVersions ResourceVersion[] @relation("ResourceVersionUploader")
  notes          Note[]         @relation("NoteAuthor")
  noteRevisions  NoteRevision[] @relation("NoteRevisionAuthor")
  favorites      Favorite[]
  downloads      DownloadRecord[]
  auditLogs      AuditLog[]     @relation("AuditActor")

  @@index([role])
  @@index([disabledAt])
}

model Session {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  tokenHash    String    @unique
  csrfTokenHash String
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Semester {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  startsAt    DateTime
  endsAt      DateTime
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  courses     Course[]

  @@unique([name])
  @@index([archivedAt])
}

model Course {
  id          String         @id @default(uuid()) @db.Uuid
  semesterId  String         @db.Uuid
  code        String
  title       String
  description String?
  archivedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  semester    Semester       @relation(fields: [semesterId], references: [id])
  members     CourseMember[]
  invitations Invitation[]
  resources   Resource[]
  notes       Note[]

  @@unique([semesterId, code])
  @@index([semesterId])
  @@index([archivedAt])
}

model CourseMember {
  id        String           @id @default(uuid()) @db.Uuid
  courseId  String           @db.Uuid
  userId    String           @db.Uuid
  role      CourseMemberRole
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@index([role])
}

model Invitation {
  id               String           @id @default(uuid()) @db.Uuid
  codeHash         String           @unique
  scope            InvitationScope
  courseId         String?          @db.Uuid
  membershipRole   CourseMemberRole @default(MEMBER)
  expiresAt        DateTime
  usageLimit       Int
  usedCount        Int              @default(0)
  revokedAt        DateTime?
  createdById      String           @db.Uuid
  createdAt        DateTime         @default(now())
  course           Course?          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy        User             @relation("InvitationCreator", fields: [createdById], references: [id])

  @@index([codeHash])
  @@index([courseId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model ResourceCategory {
  id        String     @id @default(uuid()) @db.Uuid
  key       String     @unique
  label     String
  sortOrder Int        @default(0)
  resources Resource[]
}

model Resource {
  id            String              @id @default(uuid()) @db.Uuid
  courseId      String              @db.Uuid
  categoryId    String              @db.Uuid
  uploaderId    String              @db.Uuid
  title         String
  description   String?
  visibility    ResourceVisibility  @default(COURSE_MEMBERS)
  currentVersionId String?          @unique @db.Uuid
  deletedAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  course        Course              @relation(fields: [courseId], references: [id])
  category      ResourceCategory    @relation(fields: [categoryId], references: [id])
  uploader      User                @relation("ResourceUploader", fields: [uploaderId], references: [id])
  currentVersion ResourceVersion?   @relation("CurrentResourceVersion", fields: [currentVersionId], references: [id])
  versions      ResourceVersion[]   @relation("ResourceVersions")
  tags          ResourceTag[]
  favorites     Favorite[]
  downloads     DownloadRecord[]

  @@index([courseId, createdAt])
  @@index([uploaderId])
  @@index([categoryId])
  @@index([visibility])
  @@index([deletedAt])
}

model ResourceVersion {
  id               String    @id @default(uuid()) @db.Uuid
  resourceId       String    @db.Uuid
  versionNumber    Int
  uploaderId       String    @db.Uuid
  objectKey        String    @unique
  originalFilename String
  sizeBytes        BigInt
  mimeType         String
  sha256           String
  createdAt        DateTime  @default(now())
  resource         Resource  @relation("ResourceVersions", fields: [resourceId], references: [id], onDelete: Cascade)
  currentFor       Resource? @relation("CurrentResourceVersion")
  uploader         User      @relation("ResourceVersionUploader", fields: [uploaderId], references: [id])
  downloads        DownloadRecord[]

  @@unique([resourceId, versionNumber])
  @@index([resourceId])
  @@index([uploaderId])
  @@index([sha256])
  @@index([createdAt])
}

model Tag {
  id        String        @id @default(uuid()) @db.Uuid
  name      String        @unique
  resources ResourceTag[]
}

model ResourceTag {
  resourceId String   @db.Uuid
  tagId      String   @db.Uuid
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([resourceId, tagId])
  @@index([tagId])
}

model Note {
  id               String         @id @default(uuid()) @db.Uuid
  courseId         String         @db.Uuid
  authorId         String         @db.Uuid
  title            String
  draftContent     String         @default("")
  publishedContent String?
  visibility       NoteVisibility @default(COURSE_MEMBERS)
  publishedAt      DateTime?
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  course           Course         @relation(fields: [courseId], references: [id])
  author           User           @relation("NoteAuthor", fields: [authorId], references: [id])
  revisions        NoteRevision[]
  favorites        Favorite[]

  @@index([courseId, updatedAt])
  @@index([authorId])
  @@index([visibility])
  @@index([deletedAt])
}

model NoteRevision {
  id        String   @id @default(uuid()) @db.Uuid
  noteId    String   @db.Uuid
  authorId  String   @db.Uuid
  title     String
  content   String
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  author    User     @relation("NoteRevisionAuthor", fields: [authorId], references: [id])

  @@index([noteId, createdAt])
  @@index([authorId])
}

model Favorite {
  id         String             @id @default(uuid()) @db.Uuid
  userId     String             @db.Uuid
  targetType FavoriteTargetType
  resourceId String?            @db.Uuid
  noteId     String?            @db.Uuid
  createdAt  DateTime           @default(now())
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource?          @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  note       Note?              @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, resourceId, noteId])
  @@index([userId])
  @@index([resourceId])
  @@index([noteId])
}

model DownloadRecord {
  id                String          @id @default(uuid()) @db.Uuid
  userId            String          @db.Uuid
  resourceId        String          @db.Uuid
  resourceVersionId String          @db.Uuid
  createdAt         DateTime        @default(now())
  user              User            @relation(fields: [userId], references: [id])
  resource          Resource        @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  resourceVersion   ResourceVersion @relation(fields: [resourceVersionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([resourceId])
  @@index([resourceVersionId])
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  actorId    String?     @db.Uuid
  action     AuditAction
  targetType String
  targetId   String?
  courseId   String?     @db.Uuid
  metadata   Json?
  createdAt  DateTime    @default(now())
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([courseId])
  @@index([createdAt])
}
