# Local development values only. Replace every secret before production use.

NODE_ENV=development
APP_NAME=StudyHub
APP_BASE_URL=http://localhost:3000
API_PORT=4000
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:4000

DATABASE_URL=postgresql://studyhub:studyhub_dev_password@localhost:5432/studyhub?schema=public
TEST_DATABASE_URL=postgresql://studyhub:studyhub_dev_password@localhost:5432/studyhub_test?schema=public

POSTGRES_USER=studyhub
POSTGRES_PASSWORD=studyhub_dev_password
POSTGRES_DB=studyhub

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=studyhub_minio
S3_SECRET_ACCESS_KEY=studyhub_minio_dev_password
S3_BUCKET=studyhub-private
S3_FORCE_PATH_STYLE=true
S3_PRESIGNED_TTL_SECONDS=300

SESSION_COOKIE_NAME=studyhub_session
CSRF_COOKIE_NAME=studyhub_csrf
COOKIE_SECRET=replace-with-at-least-32-random-bytes
SESSION_TTL_HOURS=168
CSRF_SECRET=replace-with-a-different-32-byte-random-value

MAX_UPLOAD_BYTES=104857600
USER_STORAGE_QUOTA_BYTES=5368709120
TEXT_PREVIEW_LIMIT_BYTES=262144

SEED_ADMIN_EMAIL=admin@example.test
SEED_ADMIN_PASSWORD=ChangeMe-Admin-DevOnly-12345
SEED_MEMBER_EMAIL=member@example.test
SEED_MEMBER_PASSWORD=ChangeMe-Member-DevOnly-12345
SEED_READONLY_EMAIL=readonly@example.test
SEED_READONLY_PASSWORD=ChangeMe-Readonly-DevOnly-12345
SEED_COURSE_ADMIN_EMAIL=course-admin@example.test
SEED_COURSE_ADMIN_PASSWORD=ChangeMe-CourseAdmin-DevOnly-12345
SEED_INVITATION_CODE=DEV-INVITE-STUDYHUB-ONLY
